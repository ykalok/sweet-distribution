# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/sweet_distribution
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10

# JWT Configuration (Generate a secure 256-bit secret)
JWT_SECRET=your_256_bit_secret_key_here_must_be_very_long_and_secure
JWT_EXPIRATION=86400000

# Razorpay Configuration (Replace with live keys for production)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Application Configuration
PORT=8080
LOG_LEVEL=INFO

# Docker Compose specific
DB_PASSWORD=your_secure_password_here